# Base de données MySQL
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/monbacfrancais"

# JWT
JWT_SECRET="change_this_secret_very_long_string"
JWT_REFRESH_SECRET="change_this_refresh_secret_very_long_string"
JWT_EXPIRES_IN="15m"

# Serveur
PORT=4000
NODE_ENV=development

# Frontend URL (pour CORS)
FRONTEND_URL="http://localhost:3001"

# Cloudinary (stockage des logos/images)
CLOUDINARY_CLOUD_NAME="votre_cloud_name"
CLOUDINARY_API_KEY="votre_api_key"
CLOUDINARY_API_SECRET="votre_api_secret"

